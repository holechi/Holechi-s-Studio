rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Stories Rules
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isValidId(storyId) 
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().content is string && incoming().content.size() <= 20000;
      allow update, delete: if true;
    }

    // 2. Photos Rules
    match /photos/{photoId} {
      allow read: if true;
      allow create: if isValidId(photoId)
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().description is string && incoming().description.size() <= 5000;
      allow update, delete: if true;
    }

    // 3. Travels Rules
    match /travels/{travelId} {
      allow read: if true;
      allow create: if isValidId(travelId)
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().content is string && incoming().content.size() <= 20000;
      allow update, delete: if true;
    }

    // 4. Friend Posts Rules
    match /friendPosts/{postId} {
      allow read: if true;
      allow create: if isValidId(postId)
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().content is string && incoming().content.size() <= 20000;
      allow update, delete: if true;
    }

    // 5. Library Items Rules
    match /libraryItems/{itemId} {
      allow read: if true;
      allow create: if isValidId(itemId)
        && incoming().title is string && incoming().title.size() <= 300;
      allow update, delete: if true;
    }

    // 6. Notices Rules
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isValidId(noticeId)
        && incoming().title is string && incoming().title.size() <= 300
        && incoming().content is string && incoming().content.size() <= 20000;
      allow update, delete: if true;
    }

    // 7. Guestbooks Rules
    match /guestbooks/{guestId} {
      allow read: if true;
      allow create: if isValidId(guestId)
        && incoming().nickname is string && incoming().nickname.size() <= 100
        && incoming().content is string && incoming().content.size() <= 5000;
      allow update, delete: if true;
    }

    // 8. Global Settings & Stats Rules
    match /settings/{settingsId} {
      allow read, write: if true;
    }
  }
}
